# Copy this file to .env and replace every REQUIRED value before starting Docker.
# See docs/configuration.md for variable scope and construction guidance.
# Never commit .env. Never use real production credentials as decoy values.

# Browser-visible gateway URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Gateway
APP_ENV=development
MIRAGE_INTERNAL_API_URL=http://gateway:8000
FRONTEND_ORIGIN=http://localhost:3000
RISK_THRESHOLD=60
ANOMALY_REDIRECT_CONFIDENCE=0.5
RATE_LIMIT_PER_MINUTE=120
REAL_APP_URL=http://localhost:8001
DECOY_SERVICE_URL=http://localhost:8002
PROXY_TIMEOUT_SECONDS=10
PROXY_MAX_BODY_BYTES=1048576
MIRAGE_MODEL_ARTIFACT=
MIRAGE_RETRAINING_ARTIFACT_DIR=artifacts/retraining
ML_SHADOW_MONITOR_THRESHOLD=0.35
ML_SHADOW_REDIRECT_THRESHOLD=0.65

# REQUIRED: operator API key and gateway database connection string.
# DATABASE_URL must use the postgresql+asyncpg driver and Docker host `db`.
# Its user, password, and database must match POSTGRES_* below.
MIRAGE_API_KEY=
DATABASE_URL=

# Docker Compose / PostgreSQL
POSTGRES_USER=mirage
POSTGRES_DB=mirage
# REQUIRED: use a strong URL-safe value and use the same value in DATABASE_URL.
POSTGRES_PASSWORD=

# REQUIRED: synthetic values exposed only by decoy responses.
# These must never be valid credentials for any real system.
DECOY_LOGIN_TOKEN=
DECOY_OAUTH_TOKEN=
DECOY_SERVICE_TOKEN=
DECOY_DATABASE_URL=postgresql://db:5432/decoy
