# Copy this file to apps/gateway/.env for standalone gateway development.
# Never commit the resulting .env file.

APP_ENV=development
APP_NAME=Project MIRAGE Gateway
API_VERSION=0.1.0
FRONTEND_ORIGIN=http://localhost:3000
RISK_THRESHOLD=60
ANOMALY_REDIRECT_CONFIDENCE=0.5
RATE_LIMIT_PER_MINUTE=120
DATABASE_URL=sqlite+aiosqlite:///./mirage.db
HOST=0.0.0.0
PORT=8000
REAL_APP_URL=http://localhost:8001
DECOY_SERVICE_URL=http://localhost:8002
PROXY_TIMEOUT_SECONDS=10
PROXY_MAX_BODY_BYTES=1048576
MIRAGE_MODEL_ARTIFACT=
MIRAGE_RETRAINING_ARTIFACT_DIR=artifacts/retraining
ML_SHADOW_MONITOR_THRESHOLD=0.35
ML_SHADOW_REDIRECT_THRESHOLD=0.65

# Optional locally, required for authenticated write endpoints.
MIRAGE_API_KEY=

# Synthetic decoy-only values. Never place real credentials here.
DECOY_LOGIN_TOKEN=
DECOY_OAUTH_TOKEN=
DECOY_SERVICE_TOKEN=
DECOY_CANARY_EPOCH=v1
DECOY_DATABASE_URL=postgresql://localhost:5432/decoy
